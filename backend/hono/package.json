{
  "name": "hono-todo-api",
  "version": "1.0.0",
  "description": "TODO API built with Hono",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:pull": "prisma db pull"
  },
  "dependencies": {
