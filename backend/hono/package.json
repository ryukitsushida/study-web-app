    "@hono/zod-validator": "^0.5.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "dotenv": "^17.4.0",
    "hono": "^4.7.6",
    "pg": "^8.20.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.21.0",
    "@types/node": "^20.17.32",
    "@types/pg": "^8.20.0",
    "prisma": "^7.6.0",
    "testcontainers": "^10.21.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
